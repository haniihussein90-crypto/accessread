# AccessRead — required environment variables (set these in Vercel, server-side).
# Do NOT use the REACT_APP_ prefix for any of these — that would expose them in
# the browser bundle. These are read only by the /api serverless functions.

# Anthropic (OCR vision + AI analysis/chat). Generate at console.anthropic.com
CLAUDE_API_KEY=

# ElevenLabs multilingual TTS (eleven_multilingual_v2)
ELEVENLABS_API_KEY=

# Stripe — live or test keys from dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The recurring Price ID for the $2.99/mo Premium subscription (price_...)
STRIPE_PRICE_ID=

# Supabase — frontend (public anon key, safe in the browser bundle)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Supabase — backend only (service role key; NEVER expose to the browser).
# Used by /api/auth-callback and /api/stripe-webhook to write premium status.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
